type Dictionary {
    id: ID!
    dictionaryType: String!
    dictionaryName: String!
    createdAt: String!
}

input CreateDictionaryInput {
    dictionaryType: String!
    dictionaryName: String!
}

type Query {
    dictionaries: [Dictionary!]!
}

type Mutation {
    createDictionary(input: CreateDictionaryInput!): Dictionary!
    deleteDictionaryById(id: ID!): Boolean!
}